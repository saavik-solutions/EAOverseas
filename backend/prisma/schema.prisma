generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum Role {
  student
  vendor
  counsellor
  admin
  super_admin
}

enum VerificationStatus {
  pending
  verified
  rejected
}

enum FeedCategory {
  admissions
  scholarships
  exams
  news
  visa
  events
}

enum PostStatus {
  draft
  published
  archived
}

enum InteractionType {
  like
  dislike
  bookmark
  view
}

enum DegreeType {
  bachelors
  masters
  phd
  diploma
  certificate
  associate
}

enum UniversityType {
  public
  private
  autonomous
}

enum AICategory {
  high
  moderate
  low
  very_low
}

enum CollegePriority {
  reach
  match
  safety
}

enum ApplicationStatus {
  draft
  submitted
  pending
  under_review
  accepted
  rejected
  waitlisted
  withdrawn
}

enum ApplicationPriority {
  urgent
  high
  medium
  low
}

enum FeeStatus {
  unpaid
  paid
  waived
}

enum DocType {
  transcript
  sop
  lor
  passport
  cv_resume
  english_test
  financial_proof
  other
}

enum PlanStatus {
  active
  completed
  abandoned
}

enum CurrentLevel {
  class_10
  class_11
  class_12
  ug_year_1
  ug_year_2
  ug_year_3
  ug_final
  pg
  phd
  working_professional
}

enum Stream {
  science
  commerce
  arts
  engineering
  medicine
  law
  other
}

enum TargetDegree {
  bachelors
  masters
  phd
  mba
  diploma
}

// --- MODELS ---

model User {
  id              String        @id @default(uuid()) @db.Uuid
  email           String        @unique
  passwordHash    String?       @map("password_hash")
  fullName        String        @map("full_name")
  phone           String?
  avatarUrl       String?       @map("avatar_url")
  role            Role          @default(student)
  emailVerified   Boolean       @default(false) @map("email_verified")
  googleId        String?       @unique @map("google_id")
  studentId       String?       @unique @map("student_id")
  authProvider    String        @default("email") @map("auth_provider")
  isActive        Boolean       @default(true) @map("is_active")
  deletedAt       DateTime?     @map("deleted_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  lastLoginAt     DateTime?     @map("last_login_at")

  refreshTokens   RefreshToken[]
  emailOtps       EmailOTP[]
  profile         UserProfile?
  testScores      TestScore[]
  educationHistory EducationHistory[]
  documents       UserDocument[]
  feedPosts       FeedPost[]
  feedInteractions FeedInteraction[]
  savedColleges   SavedCollege[]
  aiComparisons   AIComparison[]
  actionPlans     ActionPlan[]
  applications    Application[]
  apiKeys         ApiKey[]
  communityPosts    CommunityPost[]    @relation("CommunityAuthor")
  communityComments CommunityComment[] @relation("CommunityCommenter")
  communityVotes    CommunityVote[]    @relation("CommunityVoter")

  @@map("users")
}

model ApiKey {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    // e.g., "Admin Dashboard Production"
  keyHash      String    @unique @map("key_hash")
  role         Role      @default(admin)
  isActive     Boolean   @default(true) @map("is_active")
  lastUsedAt   DateTime? @map("last_used_at")
  expiresAt    DateTime? @map("expires_at")
  ownerId      String?   @db.Uuid @map("owner_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  owner        User?     @relation(fields: [ownerId], references: [id])

  @@map("api_keys")
}

model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid @map("user_id")
  tokenHash    String    @unique @map("token_hash")
  familyId     String    @default(uuid()) @db.Uuid @map("family_id")
  deviceInfo   String?   @map("device_info")
  ipAddress    String?   @map("ip_address") // Better to use String in Prisma for INET
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model EmailOTP {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid @map("user_id")
  purpose    String
  otpHash    String    @map("otp_hash")
  attempts   Int       @default(0) @db.SmallInt
  expiresAt  DateTime  @default(dbgenerated("(now() + '00:15:00'::interval)")) @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_otps")
}

model PhoneOTP {
  id         String    @id @default(uuid()) @db.Uuid
  phone      String    @unique @map("phone")
  purpose    String
  otpHash    String    @map("otp_hash")
  attempts   Int       @default(0) @db.SmallInt
  expiresAt  DateTime  @default(dbgenerated("(now() + '00:10:00'::interval)")) @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("phone_otps")
}

model UserProfile {
  id                    String        @id @default(uuid()) @db.Uuid
  userId                String        @unique @db.Uuid @map("user_id")
  currentLevel          CurrentLevel? @map("current_level")
  stream                Stream?
  tenthPercentage       Decimal?      @db.Decimal(5, 2) @map("tenth_percentage")
  twelfthPercentage     Decimal?      @db.Decimal(5, 2) @map("twelfth_percentage")
  ugCgpa                Decimal?      @db.Decimal(4, 2) @map("ug_cgpa")
  ugInstitution         String?       @map("ug_institution")
  ugGraduationYear      Int?          @db.SmallInt @map("ug_graduation_year")
  fieldOfStudy          String?       @map("field_of_study")
  targetDegree          TargetDegree? @map("target_degree")
  targetCountries       String[]      @default([]) @map("target_countries")
  targetFields          String[]      @default([]) @map("target_fields")
  budgetMinUsd          Int?          @map("budget_min_usd")
  budgetMaxUsd          Int?          @map("budget_max_usd")
  city                  String?
  state                 String?
  nationality           String        @default("Indian")
  financialAidNeeded    Boolean       @default(false) @map("financial_aid_needed")
  workExperienceMonths  Int           @default(0) @map("work_experience_months")
  gapYearMonths         Int           @default(0) @map("gap_year_months")
  extracurriculars      String[]      @default([])
  customSections        Json          @default("{}") @map("custom_sections")
  profileStrength       Int           @default(0) @db.SmallInt @map("profile_strength")
  isPublic              Boolean       @default(false) @map("is_public")
  publicSlug            String?       @unique @map("public_slug")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model TestScore {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid @map("user_id")
  examName     String    @map("exam_name") // Could use enum but SQL uses CHECK constraint
  score        Decimal   @db.Decimal(8, 2)
  maxScore     Decimal   @db.Decimal(8, 2) @map("max_score")
  percentile   Decimal?  @db.Decimal(5, 2)
  subScores    Json?     @map("sub_scores")
  examDate     DateTime? @db.Date @map("exam_date")
  validUntil   DateTime? @db.Date @map("valid_until")
  isLatest     Boolean   @default(true) @map("is_latest")
  isVerified   Boolean   @default(false) @map("is_verified")
  documentUrl  String?   @map("document_url")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("test_scores")
}

model EducationHistory {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid @map("user_id")
  institutionName String    @map("institution_name")
  degree          String?
  field           String?
  gpa             Decimal?  @db.Decimal(4, 2)
  gpaScale        Decimal?  @default(10) @db.Decimal(4, 2) @map("gpa_scale")
  percentage      Decimal?  @db.Decimal(5, 2)
  country         String?
  startDate       DateTime? @db.Date @map("start_date")
  endDate         DateTime? @db.Date @map("end_date")
  isCurrent       Boolean   @default(false) @map("is_current")
  createdAt       DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("education_history")
}

model UserDocument {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @db.Uuid @map("user_id")
  docType            DocType            @map("doc_type")
  fileName           String             @map("file_name")
  fileUrl            String             @map("file_url")
  fileSizeBytes      BigInt?            @map("file_size_bytes")
  mimeType           String?            @map("mime_type")
  verificationStatus VerificationStatus @default(pending) @map("verification_status")
  verifiedById       String?            @db.Uuid @map("verified_by_id")
  verifiedAt         DateTime?          @map("verified_at")
  notes              String?
  createdAt          DateTime           @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_documents")
}

model FeedPost {
  id            String       @id @default(uuid()) @db.Uuid
  authorId      String       @db.Uuid @map("author_id")
  title         String
  slug          String       @unique
  content       String       @db.Text
  excerpt       String?
  coverImageUrl String?      @map("cover_image_url")
  category      FeedCategory
  tags          String[]     @default([])
  status        PostStatus   @default(draft)
  universityId  String?      @db.Uuid @map("university_id")
  isPinned      Boolean      @default(false) @map("is_pinned")
  viewCount     Int          @default(0) @map("view_count")
  likeCount     Int          @default(0) @map("like_count")
  dislikeCount  Int          @default(0) @map("dislike_count")
  bookmarkCount Int          @default(0) @map("bookmark_count")
  metadata      Json?        @default("{}")
  publishedAt   DateTime?    @map("published_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  author       User              @relation(fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  university   University?       @relation(fields: [universityId], references: [id], onDelete: Cascade)
  interactions FeedInteraction[]

  @@map("feed_posts")
}

model FeedInteraction {
  id        String          @id @default(uuid()) @db.Uuid
  userId    String          @db.Uuid @map("user_id")
  postId    String          @db.Uuid @map("post_id")
  type      InteractionType
  createdAt DateTime        @default(now()) @map("created_at")

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, type])
  @@map("feed_interactions")
}

model University {
  id               String          @id @default(uuid()) @db.Uuid
  name             String
  slug             String          @unique
  country          String
  city             String?
  type             UniversityType?
  qsRanking        Int?            @map("qs_ranking")
  theRanking       Int?            @map("the_ranking")
  websiteUrl       String?         @map("website_url")
  logoUrl          String?         @map("logo_url")
  bannerUrl        String?         @map("banner_url")
  description      String?         @db.Text
  acceptanceRate   Decimal?        @db.Decimal(5, 2) @map("acceptance_rate")
  totalStudents    Int?            @map("total_students")
  intlStudentsPct  Decimal?        @db.Decimal(5, 2) @map("intl_students_pct")
  establishedYear  Int?            @db.SmallInt @map("established_year")
  campusSizeAcres  Int?            @map("campus_size_acres")
  notableAlumni    String[]        @default([]) @map("notable_alumni")
  tags             String[]        @default([])
  isActive         Boolean         @default(true) @map("is_active")
  dataVerifiedAt   DateTime?       @map("data_verified_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  courses UniversityCourse[]
  feedPosts FeedPost[]

  @@map("universities")
}

model UniversityCourse {
  id                  String      @id @default(uuid()) @db.Uuid
  universityId        String      @db.Uuid @map("university_id")
  name                String
  slug                String      @unique
  degreeType          DegreeType  @map("degree_type")
  field               String
  subField            String?     @map("sub_field")
  durationYears       Decimal?    @db.Decimal(3, 1) @map("duration_years")
  language            String      @default("English")
  intakeMonths        Int[]       @map("intake_months")
  applicationDeadline DateTime?   @db.Date @map("application_deadline")
  isActive            Boolean     @default(true) @map("is_active")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  university   University         @relation(fields: [universityId], references: [id], onDelete: Cascade)
  requirements CourseRequirement?
  fees         CourseFee?
  savedBy      SavedCollege[]
  comparisons  AIComparison[]
  actionPlans  ActionPlan[]
  applications Application[]

  @@map("university_courses")
}

model CourseRequirement {
  id                   String  @id @default(uuid()) @db.Uuid
  courseId             String  @unique @db.Uuid @map("course_id")
  minGpa               Decimal? @db.Decimal(4, 2) @map("min_gpa")
  avgGpa               Decimal? @db.Decimal(4, 2) @map("avg_gpa")
  minPercentage        Decimal? @db.Decimal(5, 2) @map("min_percentage")
  avgPercentage        Decimal? @db.Decimal(5, 2) @map("avg_percentage")
  minIelts             Decimal? @db.Decimal(3, 1) @map("min_ielts")
  avgIelts             Decimal? @db.Decimal(3, 1) @map("avg_ielts")
  minToefl             Int?     @db.SmallInt @map("min_toefl")
  minPte               Int?     @db.SmallInt @map("min_pte")
  minDuolingo          Int?     @db.SmallInt @map("min_duolingo")
  minSat               Int?     @db.SmallInt @map("min_sat")
  minGreVerbal         Int?     @db.SmallInt @map("min_gre_verbal")
  minGreQuant          Int?     @db.SmallInt @map("min_gre_quant")
  avgGreQuant          Int?     @db.SmallInt @map("avg_gre_quant")
  minGmat              Int?     @db.SmallInt @map("min_gmat")
  avgGmat              Int?     @db.SmallInt @map("avg_gmat")
  workExpYears         Decimal? @db.Decimal(3, 1) @map("work_exp_years")
  workExpRequired      Boolean @default(false) @map("work_exp_required")
  sopRequired          Boolean @default(true) @map("sop_required")
  lorCount             Int     @default(2) @db.SmallInt @map("lor_count")
  cvRequired           Boolean @default(true) @map("cv_required")
  portfolioRequired    Boolean @default(false) @map("portfolio_required")
  specificCoursesRequired String? @map("specific_courses_required")
  otherNotes           String? @map("other_notes")
  updatedAt            DateTime @default(now()) @map("updated_at")

  course UniversityCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_requirements")
}

model CourseFee {
  id                    String   @id @default(uuid()) @db.Uuid
  courseId              String   @unique @db.Uuid @map("course_id")
  tuitionPerYearUsd     Int?     @map("tuition_per_year_usd")
  avgLivingPerYearUsd   Int?     @map("avg_living_per_year_usd")
  applicationFeeUsd     Int      @default(0) @map("application_fee_usd")
  totalCostEstimateUsd  Int?     @map("total_cost_estimate_usd")
  currencyLocal         String?  @map("currency_local")
  tuitionLocal          Int?     @map("tuition_local")
  scholarshipAvailable  Boolean  @default(false) @map("scholarship_available")
  scholarshipAmountUsd  Int?     @map("scholarship_amount_usd")
  scholarshipDetails    String?  @map("scholarship_details")
  feeWaiverAvailable    Boolean  @default(false) @map("fee_waiver_available")
  feeNotes              String?  @map("fee_notes")
  updatedAt             DateTime @default(now()) @map("updated_at")

  course UniversityCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_fees")
}

model SavedCollege {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String           @db.Uuid @map("user_id")
  courseId   String           @db.Uuid @map("course_id")
  priority   CollegePriority?
  notes      String?
  savedAt    DateTime         @default(now()) @map("saved_at")

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course UniversityCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("saved_colleges")
}

model AIComparison {
  id             String      @id @default(uuid()) @db.Uuid
  userId         String      @db.Uuid @map("user_id")
  courseId       String      @db.Uuid @map("course_id")
  matchScore     Decimal     @db.Decimal(5, 2) @map("match_score")
  category       AICategory
  scoreBreakdown Json        @default("{}") @map("score_breakdown")
  strengths      String[]    @default([])
  weaknesses     String[]    @default([])
  suggestions    Json        @default("[]")
  alternatives   String[]    @default([]) @map("alternatives") // Array of UUID strings
  aiExplanation  String?     @db.Text @map("ai_explanation")
  modelVersion   String      @default("v1.0") @map("model_version")
  processingMs   Int?        @map("processing_ms")
  cached         Boolean     @default(false)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course UniversityCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  actionPlans ActionPlan[]

  @@unique([userId, courseId])
  @@map("ai_comparisons")
}

model ActionPlan {
  id             String      @id @default(uuid()) @db.Uuid
  userId         String      @db.Uuid @map("user_id")
  comparisonId   String      @db.Uuid @map("comparison_id")
  courseId       String      @db.Uuid @map("course_id")
  milestones     Json        @default("[]")
  targetIntake   String?     @map("target_intake")
  targetDate     DateTime?   @db.Date @map("target_date")
  status         PlanStatus  @default(active)
  completionPct  Int         @default(0) @db.SmallInt @map("completion_pct")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  comparison AIComparison     @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  course     UniversityCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("action_plans")
}

model Application {
  id                String              @id @default(uuid()) @db.Uuid
  userId            String              @db.Uuid @map("user_id")
  universityId      String              @db.Uuid @map("university_id")
  courseId          String              @db.Uuid @map("course_id")
  comparisonId      String?             @db.Uuid @map("comparison_id")
  status            ApplicationStatus   @default(draft)
  priority          ApplicationPriority @default(medium)
  applicationFee    Decimal?            @db.Decimal(10, 2) @map("application_fee")
  feeStatus         FeeStatus           @default(unpaid) @map("fee_status")
  feePaidAt         DateTime?           @map("fee_paid_at")
  personalStatement String?             @db.Text @map("personal_statement")
  counsellorId      String?             @db.Uuid @map("counsellor_id")
  internalNotes     String?             @db.Text @map("internal_notes")
  appliedAt         DateTime?           @map("applied_at")
  decisionAt        DateTime?           @map("decision_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course UniversityCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("applications")
}

// --- COMMUNITY FEED ---

enum CommunityCategory {
  admissions
  scholarships
  visas
  accommodation
  career_advice
  routine
  general
}

enum VoteValue {
  like
  dislike
}

model CommunityPost {
  id           String            @id @default(uuid()) @db.Uuid
  authorId     String            @db.Uuid @map("author_id")
  title        String
  content      String?           @db.Text
  imageUrl     String?           @map("image_url")
  category     CommunityCategory @default(general)
  tags         String[]          @default([])
  isQuestion   Boolean           @default(false) @map("is_question")
  isAnonymous  Boolean           @default(false) @map("is_anonymous")
  likeCount    Int               @default(0) @map("like_count")
  dislikeCount Int               @default(0) @map("dislike_count")
  commentCount Int               @default(0) @map("comment_count")
  isPinned     Boolean           @default(false) @map("is_pinned")
  isDeleted    Boolean           @default(false) @map("is_deleted")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  author   User               @relation("CommunityAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  comments CommunityComment[]
  votes    CommunityVote[]

  @@map("community_posts")
}

model CommunityComment {
  id         String   @id @default(uuid()) @db.Uuid
  postId     String   @db.Uuid @map("post_id")
  authorId   String   @db.Uuid @map("author_id")
  parentId   String?  @db.Uuid @map("parent_id")
  text       String   @db.Text
  isAnswer   Boolean  @default(false) @map("is_answer")
  isBest     Boolean  @default(false) @map("is_best")
  likeCount  Int      @default(0) @map("like_count")
  dislikeCount Int    @default(0) @map("dislike_count")
  isDeleted  Boolean  @default(false) @map("is_deleted")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  post     CommunityPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author   User               @relation("CommunityCommenter", fields: [authorId], references: [id], onDelete: Cascade)
  parent   CommunityComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  CommunityComment[] @relation("CommentReplies")
  votes    CommunityVote[]

  @@map("community_comments")
}

model CommunityVote {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @db.Uuid @map("user_id")
  postId      String?    @db.Uuid @map("post_id")
  commentId   String?    @db.Uuid @map("comment_id")
  value       VoteValue
  createdAt   DateTime   @default(now()) @map("created_at")

  user      User              @relation("CommunityVoter", fields: [userId], references: [id], onDelete: Cascade)
  post      CommunityPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment   CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@map("community_votes")
}
